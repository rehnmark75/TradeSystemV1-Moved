# Environment Variables for Azure KeyVault Migration
# Copy this file to .env and fill in your actual secret values

# IG Markets Demo/Development Credentials
DEMO_API_KEY=
DEMO_PASSWORD=

# IG Markets Production Credentials  
PROD_API_KEY=
PROD_PASSWORD=

# Gemini API Key (used in some test/old files)
GEMINI_API_KEY=

# Internal API authentication token (protects write endpoints in fastapi-live)
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=

# Enable manual position close endpoint (default: disabled for safety)
# Set to 'true' only when you explicitly need to manually flatten the live book
ENABLE_MANUAL_POSITION_CLOSE=

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Replace all placeholder values with your actual secrets
# 3. Ensure .env is in your .gitignore file to avoid committing secrets
# 4. The secrets should match what you currently have in Azure KeyVault:
#    - DEMO_API_KEY = demoapikey from KeyVault
#    - DEMO_PASSWORD = demopwd from KeyVault  
#    - PROD_API_KEY = prodapikey from KeyVault
#    - PROD_PASSWORD = prodpwd from KeyVault
#    - GEMINI_API_KEY = gemini from KeyVault